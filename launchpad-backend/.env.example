NODE_ENV=production
PORT=3000

# Supabase (required in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# MiniMax (required in production) — https://platform.minimax.io
# Token Plan / Coding Plan key (chat, TTS, music, images, web search)
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io
# Max characters per TTS call (Token Plan Plus = 4000 chars/day total)
MINIMAX_TTS_MAX_CHARS=1500
# Optional — legacy pay-as-you-go only; leave unset for Token Plan
# MINIMAX_GROUP_ID=

# Voice: openai (recommended if OPENAI_API_KEY set) | minimax
TTS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=nova
OPENAI_TTS_MAX_CHARS=4096

# Banner images: minimax (default) | pollinations | openai | placeholder
IMAGE_PROVIDER=minimax

# Production: must be false
MOCK_AI=false
DEV_BYPASS_AUTH=false
USE_MEMORY_DB=false
UPLOAD_IMAGES_TO_STORAGE=true

CORS_ORIGIN=https://your-frontend.vercel.app
