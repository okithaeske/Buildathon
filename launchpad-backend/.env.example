NODE_ENV=production
PORT=3000

# Supabase (required in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# MiniMax (required in production) — https://platform.minimax.io
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_API_BASE=https://api.minimax.io

# Tavily search for Scan/Audit (required in production) — https://tavily.com
TAVILY_API_KEY=

# Banner images: pollinations (free) | openai (paid)
IMAGE_PROVIDER=pollinations
OPENAI_API_KEY=

# Production: must be false
MOCK_AI=false
DEV_BYPASS_AUTH=false
USE_MEMORY_DB=false
UPLOAD_IMAGES_TO_STORAGE=true

CORS_ORIGIN=https://your-frontend.vercel.app
